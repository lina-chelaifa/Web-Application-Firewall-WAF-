# ── WAF Configuration ─────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git — it contains secrets.

# Origin server (the real app the WAF protects)
ORIGIN_URL=http://localhost:80

# Port the WAF proxy listens on
PROXY_PORT=8080

# Admin API port
API_PORT=5000

# JWT secret key — change this to a long random string in production!
JWT_SECRET=replace-this-with-a-very-long-random-secret-key-in-production

# SQLite database file path
DB_PATH=waf.db

# Anomaly score threshold — requests scoring >= this value are BLOCKED
# Lower = stricter, Higher = more permissive
BLOCK_THRESHOLD=5
